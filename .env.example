NEXT_PUBLIC_APP_URL=http://localhost:3000

# Convex — required
NEXT_PUBLIC_CONVEX_URL=          # Convex deployment URL (provisioned by `bunx convex dev`)

# Clerk — required
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # Clerk publishable key (from clerk.com dashboard)
CLERK_SECRET_KEY=                   # Clerk secret key (server only)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_JWT_ISSUER_DOMAIN=            # Convex env: Clerk issuer URL for the `convex` JWT template

# OpenAI — required for AI assessment (Phase 2)
# NOTE: Add this to Convex dashboard env vars, not just .env.local
OPENAI_API_KEY=

# Stripe — required for billing (Phase 4)
# NOTE: Add these to Convex dashboard env vars (Stripe code runs as Convex actions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONITORING_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
